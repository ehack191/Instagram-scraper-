# ── TELEGRAM ──────────────────────────────────────
# Step 1: Go to https://my.telegram.org
# Step 2: Log in with your phone number
# Step 3: Click "API Development Tools" → Create App
TG_API_ID=12345678               # The "App api_id" number
TG_API_HASH=abc123def456...      # The "App api_hash" string

# Your phone number with country code
TG_PHONE=+919876543210

# Your Telegram group where leads will be sent
# If group has username: @mygroupname
# If private group: use the numeric ID like -1001234567890
TG_TARGET_GROUP=@myclothingleads

# Your own Telegram user ID (so only YOU can trigger commands)
# Get it by messaging @userinfobot on Telegram — it replies with your ID
TG_ALLOWED_IDS=987654321

# ── GOOGLE MAPS API ───────────────────────────────
# Step 1: Go to https://console.cloud.google.com
# Step 2: Create a project → Enable "Places API"
# Step 3: Go to Credentials → Create API Key
GOOGLE_MAPS_API_KEY=AIzaSyXXXXXXXXXXXXXXXXXXXXXXXX

# ── HUNTER.IO ─────────────────────────────────────
# Step 1: Sign up free at https://hunter.io
# Step 2: Go to https://hunter.io/api-keys
HUNTER_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── INSTAGRAM ─────────────────────────────────────
# Use a SECONDARY burner account, not your main one
IG_USERNAME=mybrand_scraper
IG_PASSWORD=mypassword123

# ── SCRAPING SETTINGS ─────────────────────────────
MAX_LEADS_PER_QUERY=10    # Leads per city per niche (keep low to start)
SCHEDULE_HOURS=12          # Auto-scrape every 12 hours

# ── PROXY (optional for now, add later if IP gets blocked) ────────
PROXY_URL=
